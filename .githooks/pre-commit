#!/bin/bash

# Pre-commit hook to run swift-format on staged Swift files
# 1. Auto-format staged files
# 2. Verify with make format-check (same as CI)

set -e  # Exit on any error

# Get list of staged Swift files
STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=d | grep -E '\.swift$' || true)

if [ -z "$STAGED_SWIFT_FILES" ]; then
    # No Swift files staged, nothing to format
    exit 0
fi

echo "Formatting staged Swift files..."

# Format each staged Swift file
for FILE in $STAGED_SWIFT_FILES; do
    if [ -f "$FILE" ]; then
        xcrun swift-format format -i "$FILE"
        git add "$FILE"
    fi
done

echo "Running format check (same as CI)..."

if ! make format-check; then
    echo ""
    echo "Format check failed. Please fix the issues above and try again."
    exit 1
fi

echo "All files pass format check."
exit 0