#!/bin/bash

# Pre-commit hook to run swift-format on staged Swift files
# Uses the same check as CI: xcrun swift-format lint --strict

set -e  # Exit on any error

# Get list of staged Swift files
STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=d | grep -E '\.swift$' || true)

if [ -z "$STAGED_SWIFT_FILES" ]; then
    # No Swift files staged, nothing to format
    exit 0
fi

echo "Running swift-format lint on staged Swift files..."

# Check each staged Swift file with lint --strict (same as CI)
FAILED_FILES=()
for FILE in $STAGED_SWIFT_FILES; do
    if [ -f "$FILE" ]; then
        if ! xcrun swift-format lint --strict "$FILE" 2>/dev/null; then
            FAILED_FILES+=("$FILE")
        fi
    fi
done

if [ ${#FAILED_FILES[@]} -gt 0 ]; then
    echo ""
    echo "The following files have formatting issues:"
    printf '  %s\n' "${FAILED_FILES[@]}"
    echo ""
    echo "Run 'xcrun swift-format format -i <file>' to fix, or 'make format' to fix all."
    exit 1
fi

echo "All staged Swift files pass format check."
exit 0